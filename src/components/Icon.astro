---
const { name = "wifi", className = "" } = Astro.props;
---

{
  name === "wifi" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M2 8.82A16.9 16.9 0 0 1 12 5c3.8 0 7.3 1.25 10 3.82" />
        <path d="M5 12.55A11.94 11.94 0 0 1 12 10c2.7 0 5.16.9 7 2.55" />
        <path d="M8.5 16.28A6.96 6.96 0 0 1 12 15c1.35 0 2.6.38 3.5 1.28" />
        <circle cx="12" cy="19" r="1.5" fill="currentColor" stroke="none" />
      </svg>
    </span>
  ) : name === "network" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <rect x="3" y="4" width="6" height="6" rx="1.5" />
        <rect x="15" y="4" width="6" height="6" rx="1.5" />
        <rect x="9" y="14" width="6" height="6" rx="1.5" />
        <path d="M9 7h6M6 10v2.5M18 10v2.5M12 14v-4" />
      </svg>
    </span>
  ) : name === "chip" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <rect x="7" y="7" width="10" height="10" rx="2" />
        <path d="M9 1v4M15 1v4M9 19v4M15 19v4M1 9h4M1 15h4M19 9h4M19 15h4M10 10h4v4h-4z" />
      </svg>
    </span>
  ) : name === "wrench" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M14.5 6.5a4 4 0 0 0 4.74 5.13l-8.9 8.9a2 2 0 1 1-2.83-2.82l8.9-8.9A4 4 0 0 0 14.5 6.5Z" />
        <path d="M16 4l4 4" />
      </svg>
    </span>
  ) : name === "radio" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M4 18a8 8 0 0 1 16 0" />
        <path d="M7 18a5 5 0 0 1 10 0" />
        <path d="M10 18a2 2 0 0 1 4 0" />
        <circle cx="12" cy="18" r="1.2" fill="currentColor" stroke="none" />
      </svg>
    </span>
  ) : name === "server" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <rect x="4" y="4" width="16" height="6" rx="1.5" />
        <rect x="4" y="14" width="16" height="6" rx="1.5" />
        <path d="M8 7h.01M8 17h.01M12 7h6M12 17h6" />
      </svg>
    </span>
  ) : name === "code" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="m8 8-4 4 4 4M16 8l4 4-4 4M14 4l-4 16" />
      </svg>
    </span>
  ) : name === "spark" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M12 2l1.8 5.2L19 9l-5.2 1.8L12 16l-1.8-5.2L5 9l5.2-1.8L12 2Z" />
        <path d="M18.5 15l.9 2.6L22 18.5l-2.6.9-.9 2.6-.9-2.6-2.6-.9 2.6-.9.9-2.6Z" />
      </svg>
    </span>
  ) : name === "cloud" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M7 18a4 4 0 1 1 .8-7.92A5.5 5.5 0 0 1 18.5 11a3.5 3.5 0 1 1 .5 7H7Z" />
      </svg>
    </span>
  ) : name === "database" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <ellipse cx="12" cy="6" rx="7" ry="3" />
        <path d="M5 6v6c0 1.66 3.13 3 7 3s7-1.34 7-3V6" />
        <path d="M5 12v6c0 1.66 3.13 3 7 3s7-1.34 7-3v-6" />
      </svg>
    </span>
  ) : name === "chart" ? (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M4 19h16" />
        <path d="M7 16V9M12 16V5M17 16v-4" />
      </svg>
    </span>
  ) : (
    <span class={`icon ${className}`} aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path d="M2 8.82A16.9 16.9 0 0 1 12 5c3.8 0 7.3 1.25 10 3.82" />
        <path d="M5 12.55A11.94 11.94 0 0 1 12 10c2.7 0 5.16.9 7 2.55" />
        <path d="M8.5 16.28A6.96 6.96 0 0 1 12 15c1.35 0 2.6.38 3.5 1.28" />
        <circle cx="12" cy="19" r="1.5" fill="currentColor" stroke="none" />
      </svg>
    </span>
  )
}
