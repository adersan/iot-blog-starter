---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";

const {
  title = "IoT, Cloud e Indústria 4.0",
  description = "Blog educacional com aulas sobre IoT, Cloud, Arduino, Raspberry Pi, NodeMCU e Big Data.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-shell">
      <Sidebar />

      <main class="content" id="topo">
        <slot />

        <footer class="site-footer">
          <div class="site-footer-inner">
            <p>Desenvolvido por Aderval Santiago Leite</p>
          </div>
        </footer>
      </main>
    </div>
  </body>
</html>
